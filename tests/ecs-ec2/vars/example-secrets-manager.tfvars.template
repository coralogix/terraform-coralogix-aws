# Scenario 2: Secrets Manager API key, module auto-creates execution role (S3 + Secrets Manager)
# Copy to example-secrets-manager.tfvars and fill values.
# Prerequisite: resources/s3 (for config) and resources/parameter-store (for secret)
# The module auto-creates an execution role with s3:GetObject* and secretsmanager:GetSecretValue.

aws_region       = "us-east-1"
ecs_cluster_name = "ecs-cluster"

image         = "coralogixrepo/coralogix-otel-collector"
image_version = "v0.5.10"

coralogix_region = "EU1"

use_api_key_secret = true
api_key            = null
api_key_secret_arn = "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:cx_otel_api_key-tf-test-XXXXXX"

s3_config_bucket = "otel-config-dm"
s3_config_key    = "configs/otel-config.yaml"
